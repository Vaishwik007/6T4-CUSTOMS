# ─── Supabase ──────────────────────────────────────────────────────────────────
# REST/JS client keys — dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Direct Postgres URL — used ONLY by `pnpm migrate` / `pnpm setup` (not by the app).
# Dashboard → Project Settings → Database → Connection string → "Transaction pooler".
# Shape: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Admin auth JWT secret (generate: `openssl rand -hex 48` or any 48+ random bytes hex)
ADMIN_JWT_SECRET=change-me-to-a-48-byte-random-string

# Email (OTP + notifications) — get from https://resend.com
RESEND_API_KEY=
RESEND_FROM="6T4 Customs <no-reply@yourdomain.com>"

# Owner / business config
NEXT_PUBLIC_OWNER_WHATSAPP=+919999999999
NEXT_PUBLIC_GARAGE_NAME=6T4 CUSTOMS
